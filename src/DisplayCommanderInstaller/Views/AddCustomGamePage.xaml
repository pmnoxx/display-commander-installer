<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DisplayCommanderInstaller.Views.AddCustomGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" MaxWidth="560" HorizontalAlignment="Left">
            <TextBlock x:Name="PageTitle" Style="{ThemeResource TitleTextBlockStyle}" Text="Add custom game" />
            <TextBlock
                Opacity="0.85"
                Text="Pick the game executable (.exe). The install folder and display name are filled in automatically; you can change them before saving."
                TextWrapping="WrapWholeWords" />

            <TextBox x:Name="NameBox" Header="Display name" PlaceholderText="e.g. My Game" />

            <StackPanel Spacing="8">
                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="Executable" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="ExePathBox"
                        Grid.Column="0"
                        IsReadOnly="True"
                        PlaceholderText="No file selected…" />
                    <Button Grid.Column="1" VerticalAlignment="Bottom" Click="BrowseExe_Click" Content="Browse…" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="Install folder" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="InstallFolderBox"
                        Grid.Column="0"
                        PlaceholderText="Usually the folder containing the .exe" />
                    <Button Grid.Column="1" VerticalAlignment="Bottom" Click="BrowseFolder_Click" Content="Browse…" />
                </Grid>
            </StackPanel>

            <TextBlock x:Name="StatusText" Opacity="0.9" TextWrapping="WrapWholeWords" Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="Save_Click" Content="Save" Style="{ThemeResource AccentButtonStyle}" />
                <Button Click="Cancel_Click" Content="Cancel" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
