<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DisplayCommanderInstaller.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="using:DisplayCommanderInstaller.Converters"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:local="using:DisplayCommanderInstaller.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DisplayCommanderInstaller.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <LinearGradientBrush x:Key="PlayButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#FF49C35B" />
            <GradientStop Offset="1" Color="#FF239A38" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="StopButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#FF4AA3FF" />
            <GradientStop Offset="1" Color="#FF1F6FD6" />
        </LinearGradientBrush>
    </Page.Resources>
    <Grid>
        <Grid Padding="16" RowSpacing="12" ColumnSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind Vm.RefreshCommand}" Content="Refresh library" />
                <ProgressRing Width="24" Height="24" IsActive="{x:Bind Vm.IsBusy, Mode=OneWay}" />
                <TextBlock VerticalAlignment="Center" Text="{x:Bind Vm.StatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    Padding="0"
                    VerticalAlignment="Bottom"
                    automation:AutomationProperties.AutomationId="LibraryFilterButton"
                    automation:AutomationProperties.Name="Library filters"
                    ToolTipService.ToolTip="{x:Bind Vm.LibraryFilterSummary, Mode=OneWay}">
                    <Button.Flyout>
                        <MenuFlyout Opening="LibraryFilterFlyout_Opening">
                            <MenuFlyoutItem IsEnabled="False" Text="Store" />
                            <RadioMenuFlyoutItem
                                GroupName="LibraryStoreFilter"
                                Tag="S0"
                                Text="All stores"
                                Click="LibraryStoreFilterRadio_Click" />
                            <RadioMenuFlyoutItem
                                GroupName="LibraryStoreFilter"
                                Tag="S1"
                                Text="steam"
                                Click="LibraryStoreFilterRadio_Click" />
                            <RadioMenuFlyoutItem
                                GroupName="LibraryStoreFilter"
                                Tag="S2"
                                Text="epic"
                                Click="LibraryStoreFilterRadio_Click" />
                            <RadioMenuFlyoutItem
                                GroupName="LibraryStoreFilter"
                                Tag="S3"
                                Text="custom"
                                Click="LibraryStoreFilterRadio_Click" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem IsEnabled="False" Text="Show" />
                            <RadioMenuFlyoutItem
                                GroupName="LibraryListFilter"
                                Tag="L0"
                                Text="All"
                                Click="LibraryListFilterRadio_Click" />
                            <RadioMenuFlyoutItem
                                GroupName="LibraryListFilter"
                                Tag="L1"
                                Text="Favorites"
                                Click="LibraryListFilterRadio_Click" />
                            <RadioMenuFlyoutItem
                                GroupName="LibraryListFilter"
                                Tag="L2"
                                Text="RenoDX"
                                Click="LibraryListFilterRadio_Click" />
                            <RadioMenuFlyoutItem
                                GroupName="LibraryListFilter"
                                Tag="L3"
                                Text="Hidden"
                                Click="LibraryListFilterRadio_Click" />
                        </MenuFlyout>
                    </Button.Flyout>
                    <FontIcon Glyph="&#xE71C;" FontSize="16" />
                </Button>
                <TextBox
                    Grid.Column="1"
                    PlaceholderText="Search by name, id, or path…"
                    Text="{x:Bind Vm.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <ListView
                Grid.Row="2"
                Grid.Column="0"
                DoubleTapped="GameList_DoubleTapped"
                ItemsSource="{x:Bind Vm.FilteredGames, Mode=OneWay}"
                SelectedItem="{x:Bind Vm.SelectedListItem, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:UnifiedLibraryListItem">
                        <Grid Padding="4,6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image
                                Grid.Column="0"
                                Width="32"
                                Height="32"
                                VerticalAlignment="Top"
                                Source="{x:Bind Icon, Mode=OneWay}"
                                Stretch="Uniform" />
                            <StackPanel Grid.Column="1" Spacing="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Opacity="0.7" Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind StoreKind, Mode=OneWay}" />
                                    <Border
                                        Padding="4,2"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                        CornerRadius="2"
                                        Visibility="{x:Bind HasRenoDxWikiListing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock FontSize="11" Opacity="0.9" Text="RenoDX" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                Grid.Row="2"
                Grid.Column="2"
                Spacing="10"
                VerticalAlignment="Top"
                Visibility="{x:Bind Vm.HasSelectedGame, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Bind Vm.SelectedGameTitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Click="StartGame_Click"
                        Content="Play"
                        MinHeight="40"
                        FontSize="16"
                        Foreground="White"
                        Background="{StaticResource PlayButtonBrush}"
                        Visibility="{x:Bind Vm.IsSelectedGameNotRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                        Click="StopGameProcess_Click"
                        Content="Stop"
                        MinHeight="40"
                        FontSize="16"
                        Foreground="White"
                        Background="{StaticResource StopButtonBrush}"
                        Visibility="{x:Bind Vm.IsSelectedGameExecutableRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                        Click="StartViaExe_Click"
                        Content="EXE"
                        MinHeight="32"
                        MinWidth="52"
                        FontSize="13"
                        IsEnabled="{x:Bind Vm.CanStartSelectedGameViaExe, Mode=OneWay}"
                        Visibility="{x:Bind Vm.IsSelectedGameNotRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                        Click="KillGameProcess_Click"
                        Content="Kill"
                        MinHeight="32"
                        MinWidth="52"
                        FontSize="13"
                        IsEnabled="{x:Bind Vm.IsSelectedGameExecutableRunning, Mode=OneWay}"
                        Visibility="{x:Bind Vm.IsSelectedGameExecutableRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <TextBlock Opacity="0.75" Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind Vm.SelectedGamePathDisplay, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <TextBlock Opacity="0.72" Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind Vm.SelectedGameAddonPayloadsDisplay, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <TextBlock Opacity="0.85" Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind Vm.SelectedGameArchitectureDisplay, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <TextBlock Opacity="0.88" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind Vm.SelectedGameProcessStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <Expander
                    Margin="0,2,0,0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Header="Advanced"
                    IsExpanded="False"
                    Visibility="{x:Bind Vm.ShowPerGameAdvancedSettings, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Padding="0,8,0,0" Spacing="10">
                        <TextBlock
                            Opacity="0.82"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{x:Bind Vm.PerGameAdvancedHintText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <RadioButtons Header="Play button" MaxColumns="2" SelectedIndex="{x:Bind Vm.PlayLaunchPreferenceSelectedIndex, Mode=TwoWay}">
                            <x:String>Store / launcher</x:String>
                            <x:String>Game .exe</x:String>
                        </RadioButtons>
                        <TextBlock
                            Opacity="0.8"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{x:Bind Vm.PerGameExecutableOverrideSummary, Mode=OneWay}"
                            TextWrapping="WrapWholeWords"
                            IsTextSelectionEnabled="True" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="PickPerGameExecutable_Click" Content="Browse .exe…" />
                            <Button
                                Click="ClearPerGameExecutableOverride_Click"
                                Content="Use auto-detect"
                                IsEnabled="{x:Bind Vm.HasPerGameExecutableOverride, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Border
                    Padding="12"
                    CornerRadius="4"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                    Visibility="{x:Bind Vm.ShowDisplayCommanderAddonModeUi, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Display Commander" />
                        <TextBlock Opacity="0.9" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind Vm.WinMmInstallStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Opacity="0.88" Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind Vm.DisplayCommanderAddonChoiceSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <ComboBox
                            Header="Proxy DLL (this game)"
                            MinWidth="220"
                            HorizontalAlignment="Left"
                            ItemsSource="{x:Bind Vm.DisplayCommanderProxyDllComboItems, Mode=OneWay}"
                            SelectedIndex="{x:Bind Vm.DisplayCommanderProxyDllComboSelectedIndex, Mode=TwoWay}" />
                        <RadioButtons Header="Display Commander download" MaxColumns="3" SelectedIndex="{x:Bind Vm.DisplayCommanderAddonPayloadModeIndex, Mode=TwoWay}">
                            <x:String>Auto (exe)</x:String>
                            <x:String>32-bit</x:String>
                            <x:String>64-bit</x:String>
                        </RadioButtons>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="Install_Click" Content="Install Display Commander" IsEnabled="{x:Bind Vm.CanInstallDisplayCommander, Mode=OneWay}" />
                            <Button Click="Remove_Click" Content="Remove" IsEnabled="{x:Bind Vm.CanRemoveDisplayCommander, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border
                    Padding="12"
                    CornerRadius="4"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                    Visibility="{x:Bind Vm.ShowRenoDxDetailSection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="RenoDX" />
                        <TextBlock
                            Opacity="0.9"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind Vm.RenoDxAddonVersionStatusText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind Vm.ShowRenoDxAddonVersionStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock
                            Opacity="0.88"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="This game is listed on the RenoDX wiki, but there is no allowlisted in-app download URL. Install the addon from a trusted source, or open the reference link below."
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind Vm.ShowRenoDxUntrustedSourceWarning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button
                            HorizontalAlignment="Left"
                            Content="Open reference link"
                            Click="OpenRenoDxUntrustedReference_Click"
                            Visibility="{x:Bind Vm.ShowRenoDxUntrustedReferenceUrl, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Click="InstallOrUpdateRenoDxAddon_Click"
                                Content="{x:Bind Vm.RenoDxAddonInstallButtonLabel, Mode=OneWay}"
                                IsEnabled="{x:Bind Vm.CanInstallRenoDxAddon, Mode=OneWay}" />
                            <Button
                                Click="RemoveRenoDxAddon_Click"
                                Content="Remove RenoDX addon"
                                IsEnabled="{x:Bind Vm.CanUninstallRenoDxAddon, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border
                    Padding="12"
                    CornerRadius="4"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="ReShade" />
                        <TextBlock Opacity="0.9" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind Vm.LocalReShadeStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Opacity="0.9" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind Vm.GlobalReShadeStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Opacity="0.85" Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind Vm.EffectiveReShadeSourceText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="InstallOrUpdateLocalReShade_Click" Content="{x:Bind Vm.LocalReShadeInstallButtonLabel, Mode=OneWay}" IsEnabled="{x:Bind Vm.CanInstallOrUpdateLocalReShade, Mode=OneWay}" />
                            <Button Click="InstallOrUpdateGlobalReShade_Click" Content="{x:Bind Vm.GlobalReShadeInstallButtonLabel, Mode=OneWay}" IsEnabled="{x:Bind Vm.CanInstallOrUpdateGlobalReShade, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="{x:Bind Vm.IsSteamSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Click="OpenSteamStore_Click" Content="Store page" IsEnabled="{x:Bind Vm.CanOpenSteamStore, Mode=OneWay}" />
                    <Button Click="OpenSteamCommunityHub_Click" Content="Community hub" IsEnabled="{x:Bind Vm.CanOpenSteamStore, Mode=OneWay}" />
                    <Button Click="OpenSteamDiscussions_Click" Content="Discussions" IsEnabled="{x:Bind Vm.CanOpenSteamStore, Mode=OneWay}" />
                    <Button Click="OpenSteamGuides_Click" Content="Guides" IsEnabled="{x:Bind Vm.CanOpenSteamStore, Mode=OneWay}" />
                    <Button Click="OpenSteamAchievements_Click" Content="Achievements" IsEnabled="{x:Bind Vm.CanOpenSteamStore, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OpenFolder_Click" Content="Open folder" />
                    <Button Click="ToggleFavorite_Click" Content="{x:Bind Vm.FavoriteToggleButtonLabel, Mode=OneWay}" />
                    <Button Click="ToggleHidden_Click" Content="{x:Bind Vm.HiddenToggleButtonLabel, Mode=OneWay}" />
                    <Button
                        Click="OpenEpicStore_Click"
                        Content="Search Epic Store"
                        IsEnabled="{x:Bind Vm.CanSearchEpicStore, Mode=OneWay}"
                        Visibility="{x:Bind Vm.IsEpicSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <TextBlock x:Name="ActionStatus" Opacity="0.85" TextWrapping="WrapWholeWords" Visibility="Collapsed" />

                <StackPanel
                    Spacing="8"
                    Visibility="{x:Bind Vm.IsCustomSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Opacity="0.85" Text="Custom games are added from the left menu (Add custom game). You can edit the selected entry or remove it here." TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="EditCustomGame_Click" Content="Edit custom game…" />
                        <Button Click="RemoveCustomGame_Click" Content="Remove from library" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
