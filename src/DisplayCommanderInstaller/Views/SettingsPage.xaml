<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DisplayCommanderInstaller.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16" MaxWidth="720">
            <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Settings" />
            <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Display Commander download URL" />
            <TextBlock
                Opacity="0.75"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="GitHub release asset URL (downloaded bytes are written as the proxy DLL you choose below). Use a tag or latest pattern that exists on the repo. For 32-bit games, the installer substitutes addon32 for addon64 in this URL automatically."
                TextWrapping="WrapWholeWords" />
            <TextBox
                x:Name="UrlBox"
                AcceptsReturn="False"
                TextWrapping="Wrap"
                MinHeight="72" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="Save_Click" Content="Save" />
                <Button Click="Reset_Click" Content="Reset to default" />
            </StackPanel>
            <TextBlock
                x:Name="SettingsStatus"
                Opacity="0.85"
                TextWrapping="WrapWholeWords"
                Visibility="Collapsed" />
            <TextBlock
                Margin="0,24,0,0"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Proxy DLL" />
            <TextBlock
                Opacity="0.75"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="Which DLL name to drop next to the game executable. Installing a new choice removes any other Display Commander proxy this app previously installed in that folder (winmm, dxgi, version, dbghelp, vulkan-1)."
                TextWrapping="WrapWholeWords" />
            <ComboBox
                x:Name="ProxyDllCombo"
                MinWidth="280"
                SelectionChanged="ProxyDllCombo_SelectionChanged" />
            <TextBlock
                Margin="0,24,0,0"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Per-game folder" />
            <CheckBox
                x:Name="PerGameFolderCheck"
                Checked="PerGameFolderCheck_Checked"
                Content="Use per game folder"
                IsThreeState="False"
                Unchecked="PerGameFolderCheck_Unchecked" />
            <TextBlock
                Opacity="0.75"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="When enabled, creates .DC_CONFIG_GLOBAL next to the Display Commander program folder (%LocalAppData%\Programs\Display_Commander). When disabled, that file is removed."
                TextWrapping="WrapWholeWords" />
            <TextBlock
                Margin="0,24,0,0"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Global shaders marker" />
            <CheckBox
                x:Name="GlobalShadersCheck"
                Checked="GlobalShadersCheck_Checked"
                Content="Enable global shaders marker"
                IsThreeState="False"
                Unchecked="GlobalShadersCheck_Unchecked" />
            <TextBlock
                Opacity="0.75"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="When enabled, creates .DC_GLOBAL_SHADERS next to the Display Commander program folder (%LocalAppData%\Programs\Display_Commander). This enables global ReShade shader/texture search path injection for all games. When disabled, that file is removed."
                TextWrapping="WrapWholeWords" />
            <TextBlock
                Margin="0,24,0,0"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="ReShade" />
            <TextBlock
                Opacity="0.75"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="Global ReShade folder: %LocalAppData%\Programs\Display_Commander\Reshade. This checks reshade64.dll and reshade32.dll and reads file version metadata."
                TextWrapping="WrapWholeWords" />
            <TextBlock
                x:Name="ReShadeGlobalStatus"
                Opacity="0.9"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                TextWrapping="WrapWholeWords" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="UpgradeReShade_Click" Content="Install / Upgrade ReShade" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
